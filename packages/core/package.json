{
  "name": "visual-storyboard",
  "version": "0.3.5",
  "description": "Core types, transport interfaces, writer helpers, and default transports for visual-storyboard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dtinth/visual-storyboard.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "typedoc": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./integrations/playwright": {
      "typedoc": "./src/integrations/playwright.ts",
      "default": "./dist/integrations/playwright.mjs"
    },
    "./transports/file": {
      "typedoc": "./src/transports/file.ts",
      "default": "./dist/transports/file.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./integrations/playwright": "./dist/integrations/playwright.mjs",
      "./transports/file": "./dist/transports/file.mjs",
      "./package.json": "./package.json"
    },
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}
