{
  "name": "visual-storyboard",
  "version": "0.3.0",
  "description": "Core types, transport interfaces, writer helpers, and default transports for visual-storyboard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dtinth/visual-storyboard.git"
  },
  "files": [
    "dist",
    "src",
    "typedoc.json"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./integrations/playwright": "./dist/integrations/playwright.mjs",
    "./transports/file": "./dist/transports/file.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "typedoc": "vp exec typedoc --options typedoc.options.json --json typedoc.json src/index.ts src/transports/file.ts src/integrations/playwright.ts && vp fmt typedoc.json",
    "prepublishOnly": "vp run build && vp run typedoc"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typedoc": "catalog:",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "typedoc": "typedoc.json"
}
